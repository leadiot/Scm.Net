{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "运行脚本：Serve",
			"command": "npm run serve",
			"type": "node-terminal",
			"request": "launch"
		},
		{
			"name": "启动程序：Chrome",
			"request": "launch",
			"type": "chrome",
			"url": "http://localhost:2800",
			"webRoot": "${workspaceFolder}/vue"
		},
		{
			"name": "启动程序: Firefox",
			"request": "launch",
			"type": "firefox",
			"url": "http://localhost:2800",
			"webRoot": "${workspaceFolder}/vue"
		},
		{
			"name": "启动程序：Edge",
			"request": "launch",
			"type": "msedge",
			"url": "http://localhost:2800",
			"webRoot": "${workspaceFolder}/vue"
		},
		{
			"name": "Attach to Chrome",
			"request": "attach",
			"type": "chrome",
			"port": 9222,
			"webRoot": "${workspaceFolder}/vue"
		}
	]
}

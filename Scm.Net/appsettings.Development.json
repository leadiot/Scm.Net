{
  "AllowedHosts": "*",
  "Serilog": {
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "MinimumLevel": "Debug",
    "Properties": {
      "Application": "C-SCM"
    },
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "OutputTemplate": "[{Timestamp:HH:mm:ss} {Level:u11}] {Message:lj}{NewLine}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "Kestrel": {
    "Endpoints": {
      // HTTP 端点
      "Http": {
        "Url": "http://*:5000" // 监听所有IP的5000端口
      }
    },
    // 全局限制（可选）
    "Limits": {
      "MaxConcurrentConnections": 1000,
      "MaxRequestBodySize": 104857600 // 100MB（单位：字节）
    }
  },
  "Env": {
    "dataUri": "/data",
    "dataDir": "D:/data",
    "upload": "upload",
    "images": "images",
    "logs": "logs",
    "fonts": "fonts",
    "defaultFont": "DejaVu Sans"
  },
  "Sql": {
    "Type": "Sqlite",
    "Text": "Data Source=D:/data/scm.db;"
  },
  "Uid": {
    "Type": "Compose",
    "DbType": "file",
    "DbText": "D:/data/uid.db"
  },
  "Cache": {
    "Type": "Redis",
    "Text": "127.0.0.1,defaultDatabase=5,poolsize=10"
  },
  "Quartz": {
    "Type": "file",
    "BaseDir": "quartz",
    "DataDir": "data",
    "LogsDir": "logs",
    "JobFile": "jobs.json"
  },
  "Oidc": {
    "app_key": "08dc965832db7248",
    "app_secret": "50qvwk2mynnxiq20rgzrx8w8s94kfaml",
    "redirect_uri": "http://localhost:2800/#/oauth",
    "scope": "openid"
  },
  "Otp": {
    "Type": "TOTP",
    "Hotp": {
      "Algorithm": "SHA1",
      "Issuer": "Scm.Net",
      "Digits": 6,
      "Period": 30,
      "Window": 1,
      "Template": "otpauth://totp/{issuer}:{account}?secret={secret}&issuer={issuer}&algorithm={algorithm}&digits={digits}&period={period}"
    },
    "Totp": {
      "Algorithm": "SHA1",
      "Issuer": "Scm.Net",
      "Digits": 6,
      "Period": 30,
      "Window": 1,
      "Template": "otpauth://totp/{issuer}:{account}?secret={secret}&issuer={issuer}&algorithm={algorithm}&digits={digits}&period={period}"
    },
    "Phone": {

    },
    "Email": {
      "SmtpServer": "smtp.exmail.qq.com",
      "SmtpPort": 465,
      "Username": "你的邮箱账号",
      "Password": "你的邮箱密码",
      "Sender": "C-SCM"
    }
  },
  "Generator": {
    "TemplatesDir": "templates",
    "GeneratorDir": "generator",
    "SearchEnabledColumns": [ "codes", "codec", "names" ],
    "ResultIgnoredColumns": [ "id" ],
    "UpdateIgnoredColumns": [ "id", "row_status", "update_time", "update_user", "create_time", "create_user" ],
    "GenFiles": true,
    "Download": true
  },
  "Jwt": {
    "Issuer": "c-scm",
    "Audience": "scm.net",
    "Expires": 60,
    "Security": "a89f374d796890b0a05c6da2478e2569"
  },
  "Security": {
    "AppKey": "",
    "AesKey": "",
    "SignKey": "",
    "DesKey": ""
  },
  "Project": {
    "Service": [ "Scm.Core" ]
  },
  "Cors": {
    "GlobalCors": true,
    "AllowAnyOrigin": false,
    "AllowedOrigins": [ "http://localhost:2800", "https://localhost:2800" ],
    "AllowAnyMethod": true,
    "AllowedMethods": [ "GET" ],
    "AllowAnyHeader": true,
    "AllowedHeaders": [ "Content-Type" ],
    "AllowCredentials": true,
    "ExposedHeaders": [ "X-Refresh-Token" ],
    "PreflightMaxAge": 1
  },
  "Swagger": {
    "DllXmls": [ "Scm.Api.xml", "Scm.Core.xml", "Scm.Dao.xml" ],
    "ApiDocs": [
      {
        "Group": "Scm",
        "Title": "Scm Section",
        "Version": "v1",
        "Description": "默认-Scm"
      },
      {
        "Group": "Sys",
        "Title": "Sys Section",
        "Version": "v1",
        "Description": "默认-Sys"
      },
      {
        "Group": "Samples",
        "Title": "Samples Section",
        "Version": "v2",
        "Description": "示例接口-Samples"
      }
    ]
  }
}
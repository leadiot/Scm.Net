{
  "AllowedHosts": "*",
  /** 输出日志配置 **/
  "Serilog": {
    // 日志增强配置，支持：FromLogContext、WithMachineName、WithThreadId
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    // 日志级别配置，支持：Verbose < Debug < Information < Warning < Error < Fatal
    // 当前日志级别为 Information，低于该级别的日志将不会被记录
    "MinimumLevel": "Information",
    // 日志属性配置，可以在日志中添加自定义属性
    "Properties": {
      "Application": "C-SCM"
    },
    // 日志输出配置，使用 Serilog.Sinks.File 输出到文件
    "Using": [ "Serilog.Sinks.File" ],
    // 日志输出目标配置，支持：Console、File、Seq、Elasticsearch 等
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "OutputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}",
          "path": "Logs/log.txt",
          "rollingInterval": "Day"
        }
      },
      {
        "Name": "Console",
        "Args": {
          "OutputTemplate": "[{Timestamp:HH:mm:ss} {Level:u11}] {Message:lj}{NewLine}"
        }
      }
    ]
  },
  // Kestrel 配置
  "Kestrel": {
    "Endpoints": {
      // HTTP 端点
      "Http": {
        // 监听所有IP的9999端口
        "Url": "http://*:9999"
      }
    },
    // 全局限制（可选）
    "Limits": {
      "MaxConcurrentConnections": 1000,
      // 100MB（单位：字节）
      "MaxRequestBodySize": 104857600
    }
  },
  // 系统环境配置
  "Env": {
    // 网络映射路径
    "dataUri": "/data",
    // 本地物理路径
    "dataDir": "data",
    // 上传文件路径，默认相对于 dataDir
    "upload": "upload",
    // 图像文件路径，默认相对于 dataDir
    "images": "images",
    // 日志文件路径，默认相对于 dataDir
    "logs": "logs",
    // 字体文件路径，默认相对于 dataDir
    "fonts": "fonts",
    // 默认字体
    "defaultFont": "Open Sans"
  },
  // 唯一标识符配置
  "Uid": {
    // 唯一标识符生成器类型，支持：Compose、Snowflake 等
    "Type": "Compose",
    // 数据库类型，支持：File、Sqlite、MySql、PostgreSql、SqlServer 等
    "DbType": "File",
    // 数据库连接字符串，根据不同数据库类型进行配置
    "DbText": "data/uid.db"
  },
  // 数据库配置
  "Sql": {
    // 数据库类型，支持：Sqlite、MySql、PostgreSql、SqlServer 等
    "Type": "Sqlite",
    // 数据库连接字符串，根据不同数据库类型进行配置
    "Text": "Data Source=data/scm.db;"
  },
  // 缓存配置
  "Cache": {
    // 缓存类型，支持：Memory、Redis 等
    "Type": "Redis",
    // 缓存连接字符串，根据不同缓存类型进行设置
    "Text": "127.0.0.1,defaultDatabase=5,poolsize=10"
  },
  // Quartz 配置
  "Quartz": {
    "BaseDir": "quartz/settings",
    "LogsDir": "logs",
    "DataDir": "data",
    "JobFile": "jobs.json"
  },
  // MQTT 服务端配置
  "MqttBroker": {
    "Enable": false,
    "Port": 1883,
    "RequireAuthentication": false
  },
  // MQTT 客户端配置
  "MqttClient": {
    "Enable": false,
    "Host": "localhost",
    "Port": 1883
  },
  // 短信服务配置
  "Phone": {

  },
  // 邮件服务配置
  "Email": {
    "SmtpServer": "YOUR SMTP SERVER",
    "Port": 465,
    "Username": "你的邮箱账号",
    "Password": "你的邮箱密码"
  },
  // OIDC 配置
  "Oidc": {
    "app_key": "YOUR APP KEY",
    "app_secret": "YOUR APP SECRET",
    "redirect_uri": "http://localhost:2800/oauth/callback",
    "scope": "openid"
  },
  // OTP 配置
  "Otp": {
    // OTP 类型，支持：TOTP、HOTP 等
    "Type": "TOTP",
    // OTP 秘钥，建议
    "Algorithm": "SHA1",
    // OTP 发行者名称
    "Issuer": "Scm.Net",
    // OTP 数字位数
    "Digits": 6,
    // OTP 时间间隔（秒），仅对 TOTP 有效
    "Period": 30,
    // OTP 窗口大小，表示允许的时间窗口数，仅对 TOTP 有效
    "Window": 1,
    "Template": ""
  },
  // 代码生成器配置
  "Generator": {
    // 代码生成器模板目录，默认相对于环境的dataDir目录
    "TemplatesDir": "templates",
    // 代码生成器输出目录，默认相对于环境的dataDir目录
    "GeneratorDir": "generator",
    "SearchEnabledColumns": [ "codes", "codec", "names" ],
    "ResultIgnoredColumns": [ "id" ],
    "UpdateIgnoredColumns": [ "id", "row_status", "update_time", "update_user", "create_time", "create_user" ],
    // 代码生成器是否生成文件，若为 false，则仅打印生成的代码内容
    "GenFiles": true,
    // 代码生成器是否生成下载链接，若为 false，则仅打印生成的代码内容
    "Download": true
  },
  // JWT 配置
  "Jwt": {
    "Security": "a89f374d796890b0a05c6da2478e2569",
    "Issuer": "Scm.Net",
    "Audience": "scm.net",
    "Expires": 60
  },
  // CORS 配置
  "Cors": {
    // 是否启用全局 CORS，若为 true，则允许跨域请求
    "GlobalCors": true,
    // 是否允许任意来源，若为 true，则允许所有来源的请求
    "AllowAnyOrigin": false,
    // 允许的来源列表，若 AllowAnyOrigin 为 false，则必须指定允许的来源
    "AllowedOrigins": [ "http://localhost:9999", "https://localhost:9999" ],
    // 是否允许任意方法，若为 true，则允许所有 HTTP 方法的请求
    "AllowAnyMethod": true,
    // 允许的 HTTP 方法列表，若 AllowAnyMethod 为 false，则必须指定允许的方法
    "AllowedMethods": [],
    // 是否允许任意请求头，若为 true，则允许所有请求头的请求
    "AllowAnyHeader": true,
    // 允许的请求头列表，若 AllowAnyHeader 为 false，则必须指定允许的请求头
    "AllowedHeaders": [ "Content-Type", "Authorization" ],
    // 是否允许携带凭证，若为 true，则允许跨域请求携带凭证（如 Cookie、Authorization 头等）
    "AllowCredentials": true,
    // 允许的响应头列表，若 AllowCredentials 为 true，则必须指定允许的响应头
    "ExposedHeaders": [ "X-Refresh-Token" ],
    // 预检请求的缓存时间（秒），用于指定浏览器在多长时间内不再发送预检请求
    "PreflightMaxAge": 1
  },
  // 安全配置
  "Security": {
    "AppKey": "",
    "AesKey": "",
    "SignKey": "",
    "DesKey": ""
  },
  // 项目配置
  "Project": {
    "Service": [ "Scm.Core" ]
  }
}
# ==============================================================================
# Scm.Net 环境变量配置示例
# ==============================================================================
# 复制此文件为 .env 或设置环境变量
# 环境变量优先级高于 appsettings.json
# 格式: SCM__SECTION__KEY=value
# ==============================================================================

# ------------------------------------------------------------------------------
# 数据库配置
# ------------------------------------------------------------------------------
# SCM__SQL__TYPE=Sqlite
# SCM__SQL__TEXT=Data Source=data/scm.db;

# SQL Server
# SCM__SQL__TYPE=SqlServer
# SCM__SQL__TEXT=Server=localhost;Database=ScmDb;User Id=sa;Password=your_password;

# MySQL
# SCM__SQL__TYPE=MySql
# SCM__SQL__TEXT=Server=localhost;Database=scmdb;Uid=root;Pwd=your_password;

# PostgreSQL
# SCM__SQL__TYPE=PostgreSQL
# SCM__SQL__TEXT=Host=localhost;Database=scmdb;Username=postgres;Password=your_password;

# ------------------------------------------------------------------------------
# Redis 缓存配置
# ------------------------------------------------------------------------------
# SCM__CACHE__TYPE=Redis
# SCM__CACHE__TEXT=127.0.0.1,defaultDatabase=5,poolsize=10,password=your_redis_password

# ------------------------------------------------------------------------------
# JWT 配置
# ------------------------------------------------------------------------------
# SCM__JWT__SECURITY=your_256_bit_security_key_here
# SCM__JWT__ISSUER=Scm.Net
# SCM__JWT__AUDIENCE=scm.net
# SCM__JWT__EXPIRES=60

# ------------------------------------------------------------------------------
# 邮件服务配置
# ------------------------------------------------------------------------------
# SCM__EMAIL__SMTPSERVER=smtphz.qiye.163.com
# SCM__EMAIL__PORT=465
# SCM__EMAIL__USERNAME=your_email@example.com
# SCM__EMAIL__PASSWORD=your_email_password

# ------------------------------------------------------------------------------
# OIDC 认证配置
# ------------------------------------------------------------------------------
# SCM__OIDC__APP_KEY=your_oidc_client_id
# SCM__OIDC__APP_SECRET=your_oidc_client_secret
# SCM__OIDC__REDIRECT_URI=http://localhost:9999/oauth/callback
# SCM__OIDC__SCOPE=openid profile email

# ------------------------------------------------------------------------------
# 安全密钥配置
# ------------------------------------------------------------------------------
# SCM__SECURITY__APP_KEY=your_app_key
# SCM__SECURITY__AES_KEY=your_32_byte_aes_key
# SCM__SECURITY__SIGN_KEY=your_sign_key
# SCM__SECURITY__DES_KEY=your_des_key

# ------------------------------------------------------------------------------
# UID 生成配置
# ------------------------------------------------------------------------------
# SCM__UID__TYPE=Compose
# SCM__UID__DBTYPE=file
# SCM__UID__DBTEXT=Data Source=data/uid.db;

# ------------------------------------------------------------------------------
# 环境配置
# ------------------------------------------------------------------------------
# ASPNETCORE_ENVIRONMENT=Production
# SCM__ENV__DATAURI=/data
# SCM__ENV__DATADIR=data
# SCM__ENV__UPLOAD=upload
# SCM__ENV__IMAGES=images

# ------------------------------------------------------------------------------
# CORS 配置
# ------------------------------------------------------------------------------
# SCM__CORS__GLOBALCORS=true
# SCM__CORS__ALLOWANYORIGIN=false
# SCM__CORS__ALLOWEDORIGINS__0=http://localhost:9999
# SCM__CORS__ALLOWEDORIGINS__1=https://yourdomain.com

# ------------------------------------------------------------------------------
# Kestrel 配置
# ------------------------------------------------------------------------------
# ASPNETCORE_URLS=http://*:9999
# SCM__KESTREL__ENDPOINTS__HTTP__URL=http://*:9999

# ------------------------------------------------------------------------------
# 日志配置
# ------------------------------------------------------------------------------
# SCM__SERILOG__MINIMUMLEVEL=Information
